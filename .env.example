# PABADA Environment Configuration
# Copy to .env and adjust values:  cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────
# PABADA_LLM_PROVIDER is used by start.sh only (bash logic: start Ollama,
# install provider SDKs, set defaults). Python reads PABADA_LLM_MODEL,
# PABADA_LLM_API_KEY, and (optionally) PABADA_LLM_BASE_URL.
#
# The provider is auto-detected from the model prefix (e.g. "gemini/" → Gemini).
# Only set PABADA_LLM_BASE_URL for custom/self-hosted endpoints (Ollama, vLLM).

# Options: ollama, gemini, openai, anthropic, deepseek, zai
PABADA_LLM_PROVIDER=deepseek

# -- DeepSeek --
PABADA_LLM_MODEL=deepseek/deepseek-chat
PABADA_LLM_API_KEY=your-deepseek-api-key-here
# NOTE: deepseek-reasoner does NOT support function calling (tool use).

# -- Zhipu AI (Z.AI) --
# PABADA_LLM_PROVIDER=zai
# PABADA_LLM_MODEL=zai/glm-4.7-flash
# PABADA_LLM_API_KEY=your-zai-api-key-here

# -- Gemini (free tier) --
# Get your key at: https://aistudio.google.com/apikey
# PABADA_LLM_PROVIDER=gemini
# PABADA_LLM_MODEL=gemini/gemini-2.0-flash
# PABADA_LLM_API_KEY=your-gemini-api-key-here

# -- Ollama (local, default if no .env) --
# PABADA_LLM_PROVIDER=ollama
# PABADA_LLM_MODEL=qwen3-coder:30b
# PABADA_LLM_THINKING=false   # Disable thinking mode (Qwen3 <think> blocks)
# OLLAMA_HOST=http://localhost:11434

# -- OpenAI --
# PABADA_LLM_PROVIDER=openai
# PABADA_LLM_MODEL=gpt-4.1-mini
# PABADA_LLM_API_KEY=sk-...

# -- Anthropic (via LiteLLM) --
# PABADA_LLM_PROVIDER=anthropic
# PABADA_LLM_MODEL=anthropic/claude-sonnet-4-5-20250929
# PABADA_LLM_API_KEY=sk-ant-...

# ── Sandbox ─────────────────────────────────────────────────────────────
# Runs agent tools inside isolated containers (persistent pod per agent).
# Requires podman/docker and a built pabada-sandbox image.
# Set to true for production.
PABADA_SANDBOX_ENABLED=false
# Pass host GPUs into pods/containers (requires nvidia-container-toolkit).
# Podman: uses CDI (--device nvidia.com/gpu=all)
# Docker: uses --gpus all
# PABADA_SANDBOX_GPU_ENABLED=false

# ── Agent Engine ────────────────────────────────────────────────────────────
# Selects how agents execute tasks. Two engines available:
#
#   crewai      (default) — Uses CrewAI framework with LLM function calling.
#                            Works with any LiteLLM-compatible model.
#                            Does NOT require sandbox.
#
#   claude_code — Runs Claude Code CLI inside sandbox pods. Each agent gets
#                 its own container with built-in tools (Read, Write, Edit,
#                 Bash, Glob, Grep, WebSearch, WebFetch) plus the `pabada`
#                 CLI for DB operations (tasks, chat, PRs, sessions).
#
# ── Claude Code engine prerequisites ──
#   1. PABADA_SANDBOX_ENABLED=true (agents run inside pods)
#   2. Claude Code installed in sandbox image (npm i -g @anthropic-ai/claude-code)
#   3. Valid credentials at ~/.claude/.credentials.json on the host
#      (auto-copied into pods at startup by PodManager)
#   4. Rebuild sandbox image: podman build -t pabada-sandbox -f Containerfile.sandbox .
#
# ── Claude Code timeouts (seconds) ──
#   Per-role timeouts control how long an agent can run before being killed.
#   Developer tasks are longest (writing code), code review is shortest.
#
PABADA_AGENT_ENGINE=crewai
# PABADA_AGENT_ENGINE=claude_code
# PABADA_CLAUDE_CODE_MODEL=claude-sonnet-4-6       # Claude model for agents
# PABADA_CLAUDE_CODE_TIMEOUT_DEFAULT=1800           # 30 min — fallback for unknown roles
# PABADA_CLAUDE_CODE_TIMEOUT_DEVELOPER=3600         # 60 min — code writing
# PABADA_CLAUDE_CODE_TIMEOUT_CODE_REVIEWER=900      # 15 min — code review
# PABADA_CLAUDE_CODE_TIMEOUT_RESEARCHER=2400        # 40 min — research tasks
# PABADA_CLAUDE_CODE_TIMEOUT_TEAM_LEAD=1800         # 30 min — planning/coordination
# PABADA_CLAUDE_CODE_TIMEOUT_PROJECT_LEAD=1800      # 30 min — decisions/approvals
# PABADA_CLAUDE_CODE_CREDENTIALS_PATH=~/.claude/.credentials.json

# ── Web Search (SerperDev) ─────────────────────────────────────────────────
# Get your key at: https://serper.dev
# Without this key, web search falls back to DuckDuckGo.
# PABADA_SERPER_API_KEY=your-serper-api-key-here
# PABADA_SERPER_COUNTRY=us
# PABADA_SERPER_N_RESULTS=10

# ── Spider Scraper ────────────────────────────────────────────────────────
# Advanced scraping for JS-heavy sites. Get key at: https://spider.cloud
# PABADA_SPIDER_API_KEY=your-spider-api-key-here

# ── Embeddings ────────────────────────────────────────────────────────────
# Options: ollama, google, openai, default
# "default" uses ChromaDB's built-in model (no external API needed)
PABADA_EMBEDDING_PROVIDER=default

# ── CrewAI ─────────────────────────────────────────────────────────────
# Tracing shows detailed agent execution in the console
CREWAI_TRACING_ENABLED=true

# -- Ollama embeddings --
# PABADA_EMBEDDING_PROVIDER=ollama
# PABADA_EMBEDDING_MODEL=nomic-embed-text
# PABADA_EMBEDDING_BASE_URL=http://localhost:11434
