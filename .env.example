# Infinibay Environment Configuration
# Copy to .env and adjust values:  cp .env.example .env

# ── LLM ──────────────────────────────────────────────────────────────────────
# Model name in LiteLLM format. The provider is auto-detected from the prefix.
# Only set INFINIBAY_LLM_BASE_URL for custom/self-hosted endpoints (Ollama, vLLM).

# -- DeepSeek --
INFINIBAY_LLM_MODEL=deepseek/deepseek-chat
INFINIBAY_LLM_API_KEY=your-deepseek-api-key-here
# NOTE: deepseek-reasoner does NOT support function calling (tool use).

# -- Zhipu AI (Z.AI) --
# INFINIBAY_LLM_MODEL=zai/glm-4.7-flash
# INFINIBAY_LLM_API_KEY=your-zai-api-key-here

# -- Gemini (free tier) --
# Get your key at: https://aistudio.google.com/apikey
# INFINIBAY_LLM_MODEL=gemini/gemini-2.0-flash
# INFINIBAY_LLM_API_KEY=your-gemini-api-key-here

# -- Ollama (local, default if no .env) --
# INFINIBAY_LLM_MODEL=qwen3-coder:30b
# INFINIBAY_LLM_THINKING=false   # Disable thinking mode (Qwen3 <think> blocks)
# OLLAMA_HOST=http://localhost:11434

# -- OpenAI --
# INFINIBAY_LLM_MODEL=gpt-4.1-mini
# INFINIBAY_LLM_API_KEY=sk-...

# -- Anthropic --
# INFINIBAY_LLM_MODEL=anthropic/claude-sonnet-4-5-20250929
# INFINIBAY_LLM_API_KEY=sk-ant-...

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Runs agent tools inside isolated containers (persistent pod per agent).
# Requires podman/docker and a built infinibay-sandbox image.
INFINIBAY_SANDBOX_ENABLED=false
# Pass host GPUs into pods/containers (requires nvidia-container-toolkit).
# INFINIBAY_SANDBOX_GPU_ENABLED=false

# ── Web Search (SerperDev) ───────────────────────────────────────────────────
# Get your key at: https://serper.dev
# Without this key, web search falls back to DuckDuckGo.
# INFINIBAY_SERPER_API_KEY=your-serper-api-key-here

# ── Spider Scraper ───────────────────────────────────────────────────────────
# Advanced scraping for JS-heavy sites. Get key at: https://spider.cloud
# INFINIBAY_SPIDER_API_KEY=your-spider-api-key-here

# ── Embeddings (optional — auto-derived from LLM provider) ──────────────────
# Only set these if you want a different embedding provider than your LLM.
# Default: ollama→ollama, openai→openai, gemini→google, others→ChromaDB built-in
# INFINIBAY_EMBEDDING_PROVIDER=ollama
# INFINIBAY_EMBEDDING_MODEL=nomic-embed-text
# INFINIBAY_EMBEDDING_BASE_URL=http://localhost:11434
