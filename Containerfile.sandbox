# Containerfile.sandbox — lightweight image for agent command execution
# Build:  podman build -t pabada-sandbox:latest -f Containerfile.sandbox .
#         docker build -t pabada-sandbox:latest -f Containerfile.sandbox .

FROM python:3.13-slim

# ── System packages ──────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl wget tar unzip make ca-certificates \
        texlive-latex-base texlive-latex-extra latexmk \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js (LTS via fnm) ───────────────────────────────────────────────
ENV FNM_DIR="/opt/fnm"
ENV PATH="$FNM_DIR:$PATH"
RUN curl -fsSL https://fnm.vercel.app/install | bash -s -- --install-dir "$FNM_DIR" --skip-shell \
    && eval "$(fnm env)" \
    && fnm install --lts \
    && fnm default lts-latest \
    && ln -s "$(fnm exec --using=default which node)" /usr/local/bin/node \
    && ln -s "$(fnm exec --using=default which npm)" /usr/local/bin/npm \
    && ln -s "$(fnm exec --using=default which npx)" /usr/local/bin/npx \
    && node --version && npm --version

# ── Rust (via rustup, minimal profile) ───────────────────────────────────
ENV RUSTUP_HOME="/opt/rust/rustup" \
    CARGO_HOME="/opt/rust/cargo" \
    PATH="/opt/rust/cargo/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --profile minimal --default-toolchain stable \
    && rustc --version && cargo --version \
    && chmod -R a+rX /opt/rust

# ── Python packages for agent tasks ─────────────────────────────────────
RUN pip install --no-cache-dir \
        numpy pandas pytest ruff mypy \
        fpdf2 openpyxl requests beautifulsoup4

# ── File helper for pod mode ──────────────────────────────────────────────
COPY scripts/pabada_file_helper.py /usr/local/bin/pabada-file-helper
RUN chmod +x /usr/local/bin/pabada-file-helper

# ── PABADA CLI helper (for Claude Code engine) ──────────────────────────
COPY scripts/pabada_cli.py /usr/local/bin/pabada
RUN chmod +x /usr/local/bin/pabada

# ── PABADA MCP server (for Claude Code engine) ──────────────────────────
RUN pip install --no-cache-dir fastmcp
COPY scripts/pabada_mcp_server.py /usr/local/bin/pabada-mcp
RUN chmod +x /usr/local/bin/pabada-mcp

# ── Claude Code CLI (used when AGENT_ENGINE=claude_code) ─────────────
# Install globally as root, then symlink to /usr/local/bin so it's in PATH
# for non-root users (podman --userns=keep-id maps root→host user).
RUN npm install -g @anthropic-ai/claude-code \
    && ln -sf "$(npm root -g)/@anthropic-ai/claude-code/cli.js" /usr/local/bin/claude \
    && chmod -R a+rX "$(npm root -g)/@anthropic-ai" \
    && claude --version
# .claude dir must be writable by the mapped user (keep-id → non-root)
RUN mkdir -p /root/.claude && chmod 777 /root/.claude

WORKDIR /workspace

# No USER directive — pods run as root inside the container.
# Podman rootless (--userns=keep-id) maps UID 0 to the host user.
# Ephemeral containers still pass --user 1000:1000 at runtime.

# No CMD — the command is provided at runtime

